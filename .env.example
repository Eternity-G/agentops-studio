# AgentOps Studio environment template.
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# Stage 1 uses only safe defaults and does not require real API keys.

APP_NAME=AgentOps Studio
APP_ENV=development
APP_DEBUG=true

# Keep the default provider as `mock` unless you intentionally call a real model API.
MODEL_PROVIDER=mock
DEFAULT_MODEL=mock-planner-v1

# DeepSeek OpenAI-compatible provider.
# Do not commit real API keys. Copy this file to `.env` and fill values locally.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

# Other provider placeholders for later stages.
OPENAI_API_KEY=
QWEN_API_KEY=
