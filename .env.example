# AgentOps Studio environment template.
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# Stage 1 uses only safe defaults and does not require real API keys.

APP_NAME=AgentOps Studio
APP_ENV=development
APP_DEBUG=true

# Keep the default provider as `mock` until the provider adapter step is built.
MODEL_PROVIDER=mock
DEFAULT_MODEL=mock-planner-v1

# These values are placeholders for later stages.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
